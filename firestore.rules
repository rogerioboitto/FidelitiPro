rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Admin email is the only one who can access all data.
    // Identified by matching the authenticated user email.
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'rogerioboitto@gmail.com';
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    // Global config (pricing, limits, admin) — admin write, authenticated read
    match /config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Stores — each store can only read/write their own data; admin can read all
    match /stores/{storeId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == storeId);
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == storeId);

      // Customers nested under each store
      match /customers/{customerId} {
        allow read, write: if isAdmin() || (isAuthenticated() && request.auth.uid == storeId);
      }
    }

    // Platform stats — admin write/read only
    match /platform/{docId} {
      allow read, write: if isAdmin();
    }
  }
}